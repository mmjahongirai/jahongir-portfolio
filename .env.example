# Required for Next.js + @supabase/ssr (use JWT "anon" "public" key from Supabase → Settings → API)
# The key must start with eyJ...  (NOT sb_publishable_...)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Site
NEXT_PUBLIC_SITE_URL=https://jahongirai.uz

# Optional server-only secret (never NEXT_PUBLIC_)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-sb_secret_key
